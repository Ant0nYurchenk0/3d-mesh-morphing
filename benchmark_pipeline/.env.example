# Copy this file to .env and fill in your values.
# .env is never committed to version control.

# HuggingFace API token with access to extended models/spaces
HF_TOKEN=hf_your_token_here

# Delay between successive HF Space API calls (seconds).
# Increase if you hit rate limits; decrease on HF Pro.
API_DELAY_SECONDS=2.0

# Force matplotlib Agg renderer even when pyrender is available.
# Useful for local debugging on macOS.
# FORCE_MATPLOTLIB=1

# OSMesa platform selector for pyrender (set automatically in Docker via ENV).
PYOPENGL_PLATFORM=osmesa
\