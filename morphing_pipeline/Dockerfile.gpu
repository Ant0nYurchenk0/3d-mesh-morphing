# ============================================================
# 3D Mesh Morphing Pipeline — GPU image (RunPod / CUDA)
# ============================================================
# Base: pytorch/pytorch:2.2.0-cuda12.1-cudnn8-devel (Python 3.10, CUDA 12.1)
#
# What this image adds on top of the CPU Dockerfile:
#   - CUDA 12.1 + cuDNN 8 runtime and compiler toolchain
#   - pytorch3d built from source against PyTorch 2.2 CUDA kernels
#   - All pipeline deps installed via pip (no uv — torch already in base image)
#
# NOTE: This image is large (~15 GB) due to the CUDA devel base and
#       pytorch3d CUDA kernel compilation.  Build once, push, reuse on RunPod.
#
# Build (from repo root):
#   docker build --platform linux/amd64 \
#     -f morphing_pipeline/Dockerfile.gpu \
#     -t <dockerhub-user>/morphing-pipeline:gpu .
#
# Run locally (requires nvidia-docker):
#   docker run --gpus all -v $(pwd)/sessions:/app/morphing_pipeline/sessions \
#     <dockerhub-user>/morphing-pipeline:gpu \
#     --input-mesh /data/base.glb --prompt-file /data/prompt.txt --morph-method differential
# ============================================================

FROM pytorch/pytorch:2.2.0-cuda12.1-cudnn8-devel

# ── Prevent interactive apt prompts ─────────────────────────
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYOPENGL_PLATFORM=osmesa

# ── System dependencies ─────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
        # C++ build toolchain (needed for pytorch3d CUDA kernel compilation)
        git cmake build-essential ninja-build \
        # OSMesa: software OpenGL for pyrender headless rendering
        libosmesa6 libgl1 libglx-mesa0 libopengl0 \
        # Scientific Python / trimesh runtime libs
        libglib2.0-0 libgomp1 libharfbuzz0b \
        # X11 stubs (needed by some OpenGL libs even in headless mode)
        libxrender1 libxext6 \
        # ManifoldPlus build deps
        libeigen3-dev \
        libboost-filesystem-dev libboost-system-dev libboost-thread-dev libtbb-dev \
        # Instant Meshes build deps (GLFW → X11 + OpenGL headers)
        libgl-dev libx11-dev libxi-dev libxinerama-dev \
        libxcursor-dev libxrandr-dev libxxf86vm-dev \
        # xvfb: virtual framebuffer for running Instant Meshes headlessly
        xvfb xauth \
    && rm -rf /var/lib/apt/lists/*

# ── Build ManifoldPlus from source ──────────────────────────
RUN git clone --depth=1 --recurse-submodules https://github.com/hjwdzh/ManifoldPlus /tmp/ManifoldPlus \
    && ln -sf /usr/include/eigen3/Eigen /usr/include/Eigen \
    && cmake -S /tmp/ManifoldPlus -B /tmp/ManifoldPlus/build \
             -DCMAKE_BUILD_TYPE=Release \
             -DEIGEN3_INCLUDE_DIR=/usr/include/eigen3 \
    && cmake --build /tmp/ManifoldPlus/build --parallel "$(nproc)" \
    && install -m755 /tmp/ManifoldPlus/build/manifold /usr/local/bin/manifoldplus \
    && rm -rf /tmp/ManifoldPlus

# ── Python dependencies ──────────────────────────────────────
# torch 2.2 + CUDA 12.1 is already installed in the base image — do NOT reinstall.
# Install everything else the pipeline needs.
RUN pip install --no-cache-dir \
        "trimesh[easy]>=4.4.0,<5.0" \
        "scipy>=1.13,<2.0" \
        "numpy>=1.26,<2.0" \
        "matplotlib>=3.9" \
        "gradio-client>=1.3.0" \
        "requests>=2.32" \
        "pyyaml>=6.0.3" \
        "pillow>=10.0" \
        "python-dotenv>=1.0" \
        "tqdm>=4.66" \
        "huggingface-hub>=0.23" \
        "langgraph>=0.2,<1.0" \
        "typing-extensions>=4.9" \
        "openai>=1.30" \
        "scikit-image>=0.21.0" \
        "fast-simplification>=0.1.13" \
        "pyrender>=0.1.45" \
        "PyOpenGL>=3.1.0" \
        "pymeshlab>=2023.12" \
        # pytorch3d prerequisites
        "fvcore>=0.1.5" \
        "iopath>=0.1.9"

# ── Build pytorch3d from source ──────────────────────────────
# This step compiles CUDA kernels against the installed PyTorch 2.2 + CUDA 12.1.
# MAX_JOBS=4 limits parallel compilation to prevent OOM during nvcc compilation.
# Expect 20–40 min build time depending on available cores.
RUN FORCE_CUDA=1 \
    TORCH_CUDA_ARCH_LIST="7.5;8.0;8.6;8.9" \
    MAX_JOBS=4 \
    pip install --no-build-isolation --no-cache-dir \
    "git+https://github.com/facebookresearch/pytorch3d.git@stable"

# ── Application code ─────────────────────────────────────────
ENV PYTHONPATH=/app
WORKDIR /app/morphing_pipeline
COPY morphing_pipeline/ .
COPY shared/ /app/shared/
RUN mkdir -p sessions

# ── Entry point ──────────────────────────────────────────────
# Keep the container alive so RunPod SSH stays connected.
# To run the pipeline once SSHed in:
#   python run_morphing.py --input-mesh /workspace/base.glb --prompt-file /workspace/prompt.txt ...
CMD ["sleep", "infinity"]
